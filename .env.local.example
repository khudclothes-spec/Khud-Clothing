# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public keys (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key (server-only — NEVER prefix with NEXT_PUBLIC_)
# Used only in server-side admin operations and upload scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────
# The public site origin. Drives canonical URLs, Open Graph/link previews, the
# sitemap and robots.txt. Locally this is fine as localhost, but IN PRODUCTION
# you MUST set it to your real, verified domain EXACTLY as in Google Search
# Console — same scheme (https) and same host (with or without "www").
# If it's left as localhost, the deployed sitemap lists http://localhost:3000/...
# URLs and Google rejects them with "URL is not allowed". Rebuild after changing.
# If unset, the code falls back to the production domain https://charmeem.com.
#   e.g. NEXT_PUBLIC_SITE_URL=https://charmeem.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email (order confirmation + owner + status update) ────────
# Transport: Resend (https://resend.com). Create an API key and verify a
# sending domain, then set the two values below. If RESEND_API_KEY is unset,
# order emails are skipped (logged) so local checkout still works.
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=Char Meem Clothing <orders@yourdomain.com>

# The four owner notification recipients (one email per owner).
OWNER_EMAIL_1=owner1@yourdomain.com
OWNER_EMAIL_2=owner2@yourdomain.com
OWNER_EMAIL_3=owner3@yourdomain.com
OWNER_EMAIL_4=owner4@yourdomain.com


# Customer-facing contact shown in emails (placeholders).
SUPPORT_EMAIL=support@yourdomain.com
WHATSAPP_NUMBER=+92 300 0000000
STORE_ADDRESS=Islamabad, Pakistan
PROCESSING_TIME=5 to 7 business days

# ── Manual bank transfer details (shown on the online-payment step) ──────────
# Public (NEXT_PUBLIC_*) so the checkout page can render them. These are the
# ONLY source of the account shown to customers — never hardcode them in code.
# If left blank, the payment page shows a "contact us" note instead.
NEXT_PUBLIC_BANK_NAME=Meezan Bank
NEXT_PUBLIC_ACCOUNT_TITLE=Char Meem Clothing
NEXT_PUBLIC_ACCOUNT_NUMBER=0000 0000 0000 0000
NEXT_PUBLIC_IBAN=PK00 MEZN 0000 0000 0000 0000
